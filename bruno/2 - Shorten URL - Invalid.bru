meta {
  name: Shorten URL - Invalid
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/shorten
  body: json
  auth: none
}

body:json {
  {
    "url": "not-a-url"
  }
}

assert {
  res.status: eq 400
  res.body.error: isString
}

docs {
  Fails the @Pattern("^https?://.+") check on ShortenRequest.url — expects a
  400 with { "error": "..." }.
}
