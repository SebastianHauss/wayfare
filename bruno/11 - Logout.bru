meta {
  name: Logout
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/api/auth/logout
  body: json
  auth: none
}

body:json {
  {
    "refreshToken": "{{refreshToken}}"
  }
}

assert {
  res.status: eq 204
}

docs {
  Revokes {{refreshToken}}. A subsequent Refresh Token request with the same
  value will then fail with 401.
}
