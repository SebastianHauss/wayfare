meta {
  name: Logout
  type: http
  seq: 11
}

post {
  url: {{baseUrl}}/api/auth/logout
  body: none
  auth: none
}

headers {
  X-Requested-With: WayfareApp
}

assert {
  res.status: eq 204
}

docs {
  Revokes the current refresh_token cookie and clears the auth cookies. A
  subsequent Refresh Token request then fails with 401.
}
